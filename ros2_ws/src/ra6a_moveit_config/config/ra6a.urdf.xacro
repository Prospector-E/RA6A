<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ra6a">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import ra6a urdf file -->
    <xacro:include filename="$(find ra6a)/urdf/ra6a.urdf" />

    <!-- Import control_xacro -->
    <xacro:include filename="ra6a.ros2_control.xacro" />


    <xacro:ra6a_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/>

</robot>
